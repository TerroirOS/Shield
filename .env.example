# Runtime mode: MOCK | HYBRID | TESTNET
SHIELD_RUNTIME_MODE=MOCK

# API
API_PORT=8080
DATABASE_URL=postgres://shield:shield@localhost:5432/shield
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shield-evidence
INTERNAL_JOB_TOKEN=dev-internal-token
API_BASE_URL=http://localhost:8080

# Auth (OIDC)
OIDC_ISSUER_URL=http://localhost:8081/realms/shield
OIDC_JWKS_URI=http://localhost:8081/realms/shield/protocol/openid-connect/certs
OIDC_AUDIENCE=shield-api
AUTH_DEV_MODE=true

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080

# Connectors
TRACE_API_URL=http://localhost:8090
WEATHER_PROVIDER=mock
COMMITMENT_RPC_URL=https://example-testnet-rpc.invalid
TREASURY_EXPORT_TARGET=sftp://finance.local/shield
NOTIFICATION_TARGET=slack://ops-room
