{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TerroirOS/Shield/spec/schemas/climate-event.schema.json",
  "title": "ClimateEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "program_id",
    "location",
    "observed_at",
    "data_source",
    "hazard_type",
    "severity",
    "evidence_refs",
    "integrity_hash",
    "status"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 3 },
    "program_id": { "type": "string", "minLength": 3 },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "coordinates"],
      "properties": {
        "type": { "type": "string", "const": "Point" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      }
    },
    "observed_at": { "type": "string", "format": "date-time" },
    "data_source": { "type": "string", "minLength": 1 },
    "hazard_type": {
      "type": "string",
      "enum": ["HAIL", "FROST", "DROUGHT", "HEAT", "RAINFALL", "WIND"]
    },
    "severity": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "uri"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "uri": { "type": "string", "format": "uri" }
        }
      }
    },
    "integrity_hash": { "type": "string", "pattern": "^[A-Za-z0-9:_-]{16,}$" },
    "status": {
      "type": "string",
      "enum": ["RECEIVED", "NORMALIZED", "REJECTED", "REVIEW_REQUIRED"]
    }
  }
}
